<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page_title }}</title>
    <!-- CSS -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family={{ settings.font_family }}:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: '{{ settings.font_family }}', sans-serif;
            margin: 0;
            padding: 0;
            color: {{ settings.text_color }};
            background-color: #ffffff;
        }
        
        .section {
            padding: 5rem 2rem;
            box-sizing: border-box;
        }

        .hero-section {
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 450px;
        }

        .hero-section h1 { font-size: 3.5rem; margin-bottom: 1.5rem; font-weight: 700; }
        .hero-section p { font-size: 1.25rem; margin-bottom: 2rem; max-width: 600px; opacity: 0.9; }

        .btn {
            display: inline-block;
            padding: 0.875rem 2.25rem;
            font-weight: 600;
            text-decoration: none;
            border-radius: {{ settings.button_border_radius }};
            transition: all 0.2s;
        }

        .grid-products {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2.5rem;
            max-width: 1200px;
            margin: 3rem auto 0;
        }

        .product-card {
            border: 1px solid #e2e8f0;
            border-radius: 0.5rem;
            padding: 1.5rem;
            text-align: center;
            transition: all 0.3s ease;
        }
        .product-card:hover {
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
        }

        .product-img {
            background: #f1f5f9;
            height: 240px;
            border-radius: 0.25rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #94a3b8;
        }

        .product-title { font-weight: 600; font-size: 1.125rem; margin-bottom: 0.5rem; }
        .product-price { color: {{ settings.primary_color }}; font-weight: 700; }

        .rich-text-section { max-width: 800px; margin: 0 auto; }
        
        .newsletter-section { background-color: #f8fafc; text-align: center; border-top: 1px solid #f1f5f9; }
        .newsletter-section h2 { font-size: 2rem; margin-bottom: 0.75rem; }
        .newsletter-form { display: flex; gap: 0.75rem; justify-content: center; margin-top: 2rem; }
        .newsletter-input { padding: 0.75rem 1.25rem; border-radius: {{ settings.button_border_radius }}; border: 1px solid #cbd5e1; width: 280px; }
    </style>
    {{ head_scripts | raw }}
</head>
<body>
    {{ content | raw }}
    {{ footer_scripts | raw }}
</body>
</html>
